<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="tiket_pengunjung"
    pageWidth="595" pageHeight="842" columnWidth="555">

    <parameter
        name="id_transaksi"
        class="java.lang.String"/>

    <queryString>
        <![CDATA[
       SELECT  
    d.nama_wisata, 
    dd.harga_tiket, 
    t.jumlah_tiket, 
    t.total_bayar, 
    t.tanggal
FROM transaksi t
JOIN destinasi_wisata d ON t.id_wisata = d.id_wisata
JOIN detail_destinasi dd ON dd.id_wisata = d.id_wisata
WHERE t.id_transaksi = $P{id_transaksi}
ORDER BY t.tanggal DESC  LIMIT 1
        ]]>
    </queryString>

    <field name="nama_wisata" class="java.lang.String"/>
    <field name="harga_tiket" class="java.lang.Integer"/>
    <field name="jumlah_tiket" class="java.lang.Integer"/>
    <field name="total_bayar" class="java.lang.Integer"/>
    <field name="tanggal" class="java.sql.Timestamp"/>

    <detail>
    <band height="120">

        <textField>
            <reportElement x="0" y="0" width="300" height="20"/>
            <textFieldExpression><![CDATA[$F{nama_wisata}]]></textFieldExpression>
        </textField>

        <textField>
            <reportElement x="0" y="20" width="300" height="20"/>
            <textFieldExpression><![CDATA["Harga: Rp " + $F{harga_tiket}]]></textFieldExpression>
        </textField>

        <textField>
            <reportElement x="0" y="40" width="300" height="20"/>
            <textFieldExpression><![CDATA["Jumlah: " + $F{jumlah_tiket}]]></textFieldExpression>
        </textField>

        <textField>
            <reportElement x="0" y="60" width="300" height="20"/>
            <textFieldExpression><![CDATA["Total: Rp " + $F{total_bayar}]]></textFieldExpression>
        </textField>

        <textField>
            <reportElement x="0" y="80" width="300" height="20"/>
            <textFieldExpression><![CDATA["Tanggal: " + $F{tanggal}]]></textFieldExpression>
        </textField>

    </band>
</detail>

</jasperReport>